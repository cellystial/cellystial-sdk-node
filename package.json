{
  "name": "cellystial-sdk",
  "version": "1.0.0",
  "description": "Official Cellystial SDK for Node.js & TypeScript — generate PDFs from templates via the Cellystial API.",
  "keywords": [
    "cellystial",
    "pdf",
    "pdf-generation",
    "document-generation",
    "sdk"
  ],
  "license": "MIT",
  "homepage": "https://cellystial.com",
  "author": {
    "name": "Cellystial",
    "url": "https://cellystial.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cellystial/cellystial-sdk-node.git"
  },
  "bugs": {
    "url": "https://github.com/cellystial/cellystial-sdk-node/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
